      "schema": {
        "fields": [
          {"name": "slug", "type": "string", "description": "Identifiant URL kebab-case", "constraints": {"required": true, "unique": true, "pattern": "^[a-z0-9-]+$"}},
          {"name": "commune", "type": "string", "description": "Nom officiel de la commune", "constraints": {"required": true}},
          {"name": "plafond_nu_eur_m2", "type": "number", "description": "Loyer plafond légal location nue (€/m²/mois)", "constraints": {"required": true, "minimum": 0, "maximum": 100}},
          {"name": "plafond_meuble_eur_m2", "type": "number", "description": "Loyer plafond légal location meublée (€/m²/mois)", "constraints": {"required": true, "minimum": 0, "maximum": 100}},
          {"name": "perimetre", "type": "string", "description": "Zone géographique d'application", "constraints": {"required": true}},
          {"name": "date_debut_encadrement", "type": "string", "description": "Date d'entrée en vigueur (FR free-form)", "constraints": {"required": true}},
          {"name": "autorite_prefectorale", "type": "string", "description": "Préfecture qui publie l'arrêté annuel", "constraints": {"required": true}},
          {"name": "intercommunalite", "type": "string", "description": "EPCI/Métropole de rattachement", "constraints": {"required": true}}
        ],
        "primaryKey": "slug"
      }
    },
